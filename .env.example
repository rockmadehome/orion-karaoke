# Storage paths
STORAGE_PATH=./storage
TEMP_PATH=./temp

# Database
DATABASE_URL=sqlite:///./orion.db

# AI Models
SEPARATOR_MODEL=spleeter
TRANSCRIBER_BACKEND=faster_whisper
WHISPER_MODEL_SIZE=base
# Force transcription language (ISO 639-1). Leave empty for auto-detection.
# Examples: es, en, fr, pt, de, ja
WHISPER_LANGUAGE=

# Hardware (auto = detected at startup)
# Options: auto | cuda | rocm | metal | cpu
HARDWARE_BACKEND=auto

# Subtitle style
SUBTITLE_FONT=Arial
SUBTITLE_FONT_SIZE=48
SUBTITLE_ACTIVE_COLOR=&H00FFAA00&
SUBTITLE_INACTIVE_COLOR=&H00CCCCCC&
SUBTITLE_OUTLINE_COLOR=&H00000000&
SUBTITLE_MAX_LINE_CHARS=40

# Auth (disabled by default — table exists but endpoints are inactive)
AUTH_ENABLED=false
SECRET_KEY=change-me-in-production

# Server
APP_HOST=0.0.0.0
APP_PORT=8000
